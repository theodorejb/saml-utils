{
    "name": "theodorejb/saml-utils",
    "description": "Utilities to streamline Light Saml usage",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "guzzlehttp/psr7": "^2.12",
        "litesaml/lightsaml": "^5.0.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.2.3",
        "phpunit/phpunit": "^13.2"
    },
    "autoload": {
        "psr-4": {
            "theodorejb\\SamlUtils\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "theodorejb\\SamlUtils\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "analyze": "phpstan analyze",
        "cs-fix": "php-cs-fixer fix -v",
        "test": "phpunit tests"
    },
    "authors": [
        {
            "name": "Theodore Brown",
            "email": "theodorejb@outlook.com"
        }
    ]
}
